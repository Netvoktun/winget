<?xml version="1.0" encoding="utf-8"?>
<!--
    Pin/Unpin config for Install-TaskbarPins.ps1
    
    Two types of Pin entries:
      type="win32"  -- Classic desktop app. Provide the .exe path; the script creates the .lnk.
      type="uwp"    -- Microsoft Store / UWP app. Provide the AppUserModelID (AUMID).

    Unpin entries:
      Provide the display name exactly as it appears on the taskbar.
-->
<TaskbarConfig>

    <Pin>
        <!-- Win32 apps -->
        <App type="win32" name="Word"  exe="C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE" />
        <App type="win32" name="Excel" exe="C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE" />

        <!-- UWP / Store apps -->
        <App type="uwp" name="Outlook (New)"          aumid="Microsoft.OutlookForWindows_8wekyb3d8bbwe!Microsoft.OutlookForWindows" />
        <App type="uwp" name="Microsoft Teams"         aumid="MSTeams_8wekyb3d8bbwe!MSTeams" />
        <App type="uwp" name="Microsoft 365 Copilot"   aumid="Microsoft.Copilot_8wekyb3d8bbwe!App" />
    </Pin>

    <Unpin>
        <App name="Microsoft Store" />
    </Unpin>

</TaskbarConfig>
